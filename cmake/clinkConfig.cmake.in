@PACKAGE_INIT@

# clinkConfig.cmake - generated by clink's install step.
#
# Provides the `clink::core`, `clink::clink`, and `clink::<impl>` imported
# targets to consumers calling `find_package(clink REQUIRED)`. The list
# of available impls depends on which were actually built and installed
# from the upstream clink source tree (see CLINK_AVAILABLE_IMPLS below).

include(CMakeFindDependencyMacro)

# --- Always-required core dependencies -------------------------------------
find_dependency(Threads)
find_dependency(Arrow CONFIG)
find_dependency(Parquet CONFIG)

# --- Impl-specific dependencies --------------------------------------------
# Each block was emitted at install time by an impls/<x>/CMakeLists.txt
# that actually built. Missing impls are silently absent.
@CLINK_FIND_DEPS_BODY@

# --- Targets ---------------------------------------------------------------
include("${CMAKE_CURRENT_LIST_DIR}/clinkTargets.cmake")

# Manifest of impls that were built and installed alongside this package.
# Consumers can `if(clink_kafka IN_LIST clink_AVAILABLE_IMPLS)` to gate
# usage of an optional connector.
set(clink_AVAILABLE_IMPLS "@CLINK_AVAILABLE_IMPLS@")

# Component names mirror the imported targets (core, clink, and every
# installed impl). check_required_components() reads the per-component
# _FOUND variables; without them any `COMPONENTS core` request would mark
# the whole package NOT FOUND even though the target exists.
foreach(_clink_comp ${clink_FIND_COMPONENTS})
    if(TARGET clink::${_clink_comp})
        set(clink_${_clink_comp}_FOUND TRUE)
    else()
        set(clink_${_clink_comp}_FOUND FALSE)
    endif()
endforeach()
unset(_clink_comp)

check_required_components(clink)
