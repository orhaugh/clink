@PACKAGE_INIT@

# clinkConfig.cmake - generated by clink's install step.
#
# Provides the `clink::core`, `clink::clink`, and `clink::<impl>` imported
# targets to consumers calling `find_package(clink REQUIRED)`. The list
# of available impls depends on which were actually built and installed
# from the upstream clink source tree (see CLINK_AVAILABLE_IMPLS below).

include(CMakeFindDependencyMacro)

# --- Always-required core dependencies -------------------------------------
find_dependency(Threads)

# clink links the PINNED Arrow from the toolchain prefix (CLINK_DEPS_PREFIX,
# default ~/.clink-deps; /usr/local in the project images), and a consumer
# machine's package manager frequently carries a different Arrow. The main
# build auto-prepends the prefix and asserts the version; a downstream
# find_package(clink) must do the same, or Arrow resolves to whatever the
# host has (a Homebrew Arrow with missing transitive deps was the observed
# failure) and the version contract silently breaks.
if(NOT DEFINED CLINK_DEPS_PREFIX)
    if(DEFINED ENV{CLINK_DEPS_PREFIX})
        set(CLINK_DEPS_PREFIX "$ENV{CLINK_DEPS_PREFIX}")
    elseif(DEFINED ENV{HOME})
        set(CLINK_DEPS_PREFIX "$ENV{HOME}/.clink-deps")
    endif()
endif()
if(CLINK_DEPS_PREFIX AND EXISTS "${CLINK_DEPS_PREFIX}")
    list(PREPEND CMAKE_PREFIX_PATH "${CLINK_DEPS_PREFIX}")
endif()
find_dependency(Arrow CONFIG)
if(NOT "@CLINK_PINNED_ARROW_VERSION@" STREQUAL ""
   AND NOT ARROW_VERSION VERSION_EQUAL "@CLINK_PINNED_ARROW_VERSION@")
    message(FATAL_ERROR
        "clink was built against Arrow @CLINK_PINNED_ARROW_VERSION@ but Arrow "
        "${ARROW_VERSION} resolved. Build the pinned toolchain "
        "(scripts/build-arrow.sh in the clink source tree) or point "
        "CLINK_DEPS_PREFIX at an existing pinned prefix.")
endif()
find_dependency(Parquet CONFIG)

# --- Impl-specific dependencies --------------------------------------------
# Each block was emitted at install time by an impls/<x>/CMakeLists.txt
# that actually built. Missing impls are silently absent.
@CLINK_FIND_DEPS_BODY@

# --- Bundled engine archives ------------------------------------------------
# clink::forst links the ForSt engine as an imported static archive built by
# an ExternalProject, so the archive cannot ride the export set the way an
# in-build target does. It is installed under a private name; recreate the
# imported target (the name the exported clink::forst's LINK_ONLY reference
# resolves against) before the targets file is included. Self-gating: the
# block is a no-op unless the forst impl was installed.
if(NOT TARGET clink_forst_engine
   AND EXISTS "${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_LIBDIR@/libclink_forst_engine.a")
    add_library(clink_forst_engine STATIC IMPORTED)
    set_target_properties(clink_forst_engine PROPERTIES
        IMPORTED_LOCATION "${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_LIBDIR@/libclink_forst_engine.a"
        INTERFACE_LINK_LIBRARIES Threads::Threads)
endif()

# --- Targets ---------------------------------------------------------------
include("${CMAKE_CURRENT_LIST_DIR}/clinkTargets.cmake")

# Manifest of impls that were built and installed alongside this package.
# Consumers can `if(clink_kafka IN_LIST clink_AVAILABLE_IMPLS)` to gate
# usage of an optional connector.
set(clink_AVAILABLE_IMPLS "@CLINK_AVAILABLE_IMPLS@")

# Component names mirror the imported targets (core, clink, and every
# installed impl). check_required_components() reads the per-component
# _FOUND variables; without them any `COMPONENTS core` request would mark
# the whole package NOT FOUND even though the target exists.
foreach(_clink_comp ${clink_FIND_COMPONENTS})
    if(TARGET clink::${_clink_comp})
        set(clink_${_clink_comp}_FOUND TRUE)
    else()
        set(clink_${_clink_comp}_FOUND FALSE)
    endif()
endforeach()
unset(_clink_comp)

check_required_components(clink)
