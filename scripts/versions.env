# versions.env - single source of truth for clink's pinned, from-source third-party
# toolchain. Sourced by scripts/build-arrow.sh, scripts/build-iceberg-cpp.sh,
# scripts/setup-build-env.sh (Docker) and build_and_test.sh (host), and parsed by
# CMakeLists.txt to assert the linked Arrow matches. POSIX-sh syntax (no bashisms).
#
# The toolchain is COMPILED FROM SOURCE at these exact versions into CLINK_DEPS_PREFIX
# on BOTH the macOS host and the Debian Docker image, so both link byte-for-byte the
# same Arrow/Parquet/iceberg-cpp (deps BUNDLED -> identical transitive versions too).
# Bump a version here and rebuild both environments; nothing else hard-codes them.

# Apache Arrow + Parquet (clink core links Arrow::arrow_shared + Parquet::parquet_shared;
# iceberg-cpp + impls/s3 also bind this same Arrow). Must stay one exact version across
# host + Docker or the prebuilt iceberg-cpp static libs are ABI-incompatible.
ARROW_VERSION=24.0.0

# Apache iceberg-cpp (the Iceberg table-format sink backend). Git tag.
ICEBERG_CPP_TAG=v0.3.0

# aws-sdk-cpp for Arrow's S3 FileSystem. This is the S3 TRANSPORT layer only (not the
# data path), so it is the SYSTEM aws-sdk on each platform rather than a bundled,
# data-determinism-critical dep: the macOS host uses Homebrew's aws-sdk-cpp, and the
# Debian image builds this exact tag from source so the two stay close. Arrow 24's
# OWN bundled aws-c-* CRT is mutually inconsistent and does not compile, which is why
# we use the system SDK (also how Homebrew builds Arrow).
AWS_SDK_CPP_TAG=1.11.795

# Apache Pulsar C++ client. NOT in Debian apt, so the image installs Apache's prebuilt .deb
# (apache-pulsar-client + -dev) for this exact version from archive.apache.org; the macOS host
# uses Homebrew's libpulsar, kept at the same version. clink uses the C API (pulsar/c/), so no
# C++ ABI is shared with the prebuilt library.
PULSAR_CLIENT_CPP_VERSION=4.2.0

# DataStax C/C++ driver for Apache Cassandra / ScyllaDB. No Debian package and no prebuilt arm64
# release artifact, so the image builds this exact tag from source (CMake, needs libuv); the
# macOS host uses Homebrew's cassandra-cpp-driver at the same version. clink uses the C API
# (cassandra.h), so the from-source-vs-Homebrew build is ABI-safe.
CASSANDRA_CPP_DRIVER_VERSION=2.17.1

# MongoDB C and C++ drivers for the mongodb connector (mongo_sink + change-stream source).
# mongo-cxx-driver was dropped from Debian, so the image builds both from source (CMake): the
# C++ driver (mongocxx/bsoncxx) links the C driver (libmongoc/libbson). The macOS host uses
# Homebrew's mongo-cxx-driver / mongo-c-driver at these same versions. impls/mongodb uses the
# C++ API and discovers the source install via its mongocxx CONFIG package under /usr/local.
MONGO_C_DRIVER_VERSION=2.3.1
MONGO_CXX_DRIVER_VERSION=4.4.0

# etcd-cpp-apiv3 for the etcd HaCoordinator connector (etcd-backed leader election).
# Not in Debian apt, so the image builds it from source into /usr/local. Its gRPC /
# Protobuf / cpprestsdk deps ARE apt packages (added to install-connector-deps.sh);
# c-ares + RE2 (pulled transitively by grpc) are already in the image. The installed
# CMake config package is named "etcd-cpp-api" (not -apiv3).
ETCD_CPP_APIV3_VERSION=0.15.4


# Install prefix for the from-source toolchain. Host default = ~/.clink-deps (gitignored,
# outside the repo, survives worktrees). Docker overrides this to /usr/local (on the
# default search path) before sourcing. Override by exporting CLINK_DEPS_PREFIX.
: "${CLINK_DEPS_PREFIX:=${HOME}/.clink-deps}"
