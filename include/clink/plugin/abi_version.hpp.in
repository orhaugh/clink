// This file is auto-generated by CMake at configure time. Do not edit
// by hand. It bakes the plugin-ABI compatibility values into both the
// clink binaries and any plugin built against this installed header.

#pragma once

namespace clink::plugin {

// Plugin-ABI compatibility version - the DEFAULT load gate. The loader
// accepts a plugin whose kAbiVersion equals the cluster's and refuses
// otherwise, so a plugin survives any marketing-version bump that does not
// change the ABI. Bumped by hand (CLINK_ABI_VERSION in CMakeLists.txt) only on
// an intentional ABI break. Decoupled from kClinkVersion.
inline constexpr int kAbiVersion = @CLINK_ABI_VERSION@;

// Exact commit hash of the clink source tree at build time. INFORMATIONAL:
// reported in logs / plugin metadata for diagnostics, and used as the gate only
// under the opt-in strict mode (CLINK_STRICT_PLUGIN_ABI=1), which restores the
// historic exact-match behaviour. Plugins link against the same clink package
// as the cluster they target, so the value baked into the plugin matches the
// cluster's.
inline constexpr const char* kAbiHash = "@CLINK_ABI_HASH@";

// Source tree was clean (true) or had uncommitted changes (false) at
// build time. Reported for reproducibility diagnostics.
inline constexpr bool kAbiHashIsClean = @CLINK_ABI_HASH_CLEAN@;

// Marketing (semver) version of clink at build time. Informational - the load
// gate uses kAbiVersion, not this. Reported in error messages.
inline constexpr const char* kClinkVersion = "@clink_VERSION@";

}  // namespace clink::plugin
