// This file is auto-generated by CMake at configure time. Do not edit
// by hand. The hash is computed from `git rev-parse HEAD` and embedded
// into both the clink binaries and any plugins built against this
// installed header. The plugin loader compares the two values byte for
// byte and refuses to load a plugin whose hash doesn't match the
// cluster's.

#pragma once

namespace clink::plugin {

// Exact commit hash of the clink source tree at build time. Plugins
// link against the same clink package as the cluster they target, so
// the value baked into the plugin matches the value baked into the
// cluster's binaries. Any mismatch is a hard refusal at load time -
// templated clink internals may have changed between commits and
// crossing the dlopen boundary with mismatched layouts is undefined.
inline constexpr const char* kAbiHash = "@CLINK_ABI_HASH@";

// Source tree was clean (true) or had uncommitted changes (false) at
// build time. Plugins built from dirty trees can still load, but the
// loader will log a warning since reproducibility is compromised.
inline constexpr bool kAbiHashIsClean = @CLINK_ABI_HASH_CLEAN@;

// Major-minor of clink at build time. Informational - the load gate
// uses kAbiHash. Reported in error messages.
inline constexpr const char* kClinkVersion = "@clink_VERSION@";

}  // namespace clink::plugin
